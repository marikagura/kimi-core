# ── Database (required) ───────────────────────────────
# Defaults to the docker-compose local Postgres + pgvector. Point it at your own
# Postgres / managed DB by changing only this line — same code, local or cloud.
DATABASE_URL="postgresql://kimi:kimi@localhost:5432/kimi?schema=public"

# ── Embeddings (recommended; without it, semantic search degrades to keyword/trigram) ──
OPENAI_API_KEY=""             # OpenAI key — only needed if you set EMBED_MODEL below
EMBED_MODEL=""                # embedding model, e.g. text-embedding-3-small. Must output the
                              # dimension the DB vector columns expect (shipped schema: 1536).
                              # Blank = no semantic arm (retrieval falls back to keyword/trigram).

# ── LLM (required) ──
OPENROUTER_API_KEY=""         # OpenRouter key for all LLM calls

# ── Models — bring your own; the repo ships NO built-in model ──
# KIMI_MODEL is the default for every OpenRouter call (intel / digests / depth judge /
# short helpers). An OpenRouter slug, e.g. "anthropic/claude-..." or "openai/gpt-...".
# Unset → a clear, fail-closed error (never a silent default to someone else's model).
# The per-role vars below are OPTIONAL overrides; unset, each falls back to KIMI_MODEL.
KIMI_MODEL=""                 # REQUIRED — your default LLM model
# LLM_SHORT_MODEL=""          #   short single-shot helpers
# INTEL_MODEL=""              #   intel main pass
# INTEL_DIGEST_MODEL=""       #   dialogue digest
# INTEL_SWEEP_MODEL=""        #   concern self-sweep
# INTEL_SCORE_AUTHOR_MODEL="" #   author stamp on self-scores
# DEPTH_JUDGE_MODEL=""        #   depth-talk judge
# ONBOARDING_MODEL=""         #   `npm run init` adaptive follow-up

# ── Gateway auth (required; set to a long random string) ──
# Missing → the process exits; it never falls back to a built-in default.
KIMI_API_KEY=""

# ── Optional modules (blank / none = off) ──
RERANK_PROVIDER="none"        # none | local | cohere | jina | voyage
KIMI_TZ="UTC"                 # display timezone (time.ts); IANA name, e.g. America/New_York

# ── Autonomy daemon (optional; uses the Claude Agent SDK → needs a Claude subscription. Skip if you don't run it) ──
DAEMON_AUTONOMY_MODE="propose"            # propose (default HITL: outward actions staged, not sent) | auto (commit directly)
DAEMON_MODEL=""                           # REQUIRED to run the daemon — your own BARE Claude id (e.g. "claude-..."), resolved by the Agent SDK. No built-in default.
DAEMON_WAKE_CRON="0 9,21 * * *"           # wake cron
KIMI_CRON_TZ="UTC"                        # cron timezone
KIMI_TZ_OFFSET_HOURS="0"                  # display tz offset in hours (daemon-internal)
CLAUDE_CODE_OAUTH_TOKEN=""                # daemon uses subscription OAuth (claude setup-token); missing → daemon exits at startup
KIMI_MCP_URL="http://127.0.0.1:3001/mcp"  # daemon → gateway MCP endpoint (Streamable HTTP; must match http-server.ts POST /mcp)
# ground-truth event source names — map to your own ingestion surfaces; blank uses the generic defaults
GROUND_CHAT_SOURCE="chat"
GROUND_CROSS_CHAT_SOURCE="chat_b"
GROUND_HOOK_SOURCE="client_hook"
GROUND_LOOP_SOURCE="client_loop"
GROUND_COMMIT_SOURCE="git_commit"
GROUND_CHAT_LIVE_WINDOW_H="36"            # hours the chat surfaces count as "current"; past this, rows are shown as dated history, not "just said"

# ── Delivery providers (optional; off by default — see lib/providers.ts) ──
NOTIFIER="none"               # none | console | webhook (daemon outward push)
NOTIFIER_WEBHOOK_URL=""       # webhook target (POST JSON); NOTIFIER_WEBHOOK_FIELD remaps the content key (Slack=text / ntfy=message)
SEARCH_PROVIDER="none"        # none | http (WEBSEARCH curiosity search)
SEARCH_API_URL=""             # http search endpoint; SEARCH_API_KEY + SEARCH_RESULTS_PATH + SEARCH_FIELD_* map the response

# ── Deeper tuning lives in config.example.yaml ──
# Retrieval weights/floors, the self-drive dimension roster (DRIVE_DIMS) + shapes,
# concern thresholds — all have sane defaults; override via config.example.yaml
# (or the matching env vars documented there). You don't need any of them to run.
